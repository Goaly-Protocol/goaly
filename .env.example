# ─── Chain / RPC ───────────────────────────────────────────────
# Arbitrum One RPC — used by the API, indexer, and Foundry fork tests. Use a private RPC in production.
ARBITRUM_RPC_URL="https://arb1.arbitrum.io/rpc"

# ─── Ponder indexer (apps/indexer) ─────────────────────────────
PONDER_RPC_URL_42161="https://arb1.arbitrum.io/rpc"
GOALY_VAULT_START_BLOCK="479692780"

# ─── API (apps/api) ────────────────────────────────────────────
API_PORT="3001"
DATABASE_URL="./data/goaly.db"
# goUSDT vault address — enables GET /positions:
GOALY_VAULT_ADDRESS="0xC5C51C530174857B7eCa715cFa275a0FBeaE0eb1"
# Ponder indexer base URL — when set, /positions is served from it (RPC fallback):
INDEXER_URL="http://localhost:42069"
# CORS: production origins allowed to call the API (localhost is always allowed in dev):
CORS_ORIGINS="https://goaly.fun,https://app.goaly.fun"

# ─── The Odds API (https://the-odds-api.com) ───────────────────
# ONE key …
GOALY_ODDS_URL="https://odds.goaly.fun"   # free live odds feed (preferred; empty -> The Odds API/mock)
ODDS_API_KEY=""                           # X-API-Key for the Goaly Odds feed (server-side only)
THE_ODDS_API_KEY=""
# … or MANY (comma-separated) for rotation/fallback. Each free key = 500 credits/month.
THE_ODDS_API_KEYS=""
ODDS_SPORT_KEY="soccer_fifa_world_cup"
ODDS_REGION="eu"
ODDS_MARKETS="h2h"
ODDS_MONTHLY_CREDITS="500"
ODDS_CREDIT_RESERVE="80"                 # held back for settlement (scores)
ODDS_REFRESH_INTERVAL_MS="21600000"      # min 6h between (expensive) odds refreshes
ODDS_SCORES_INTERVAL_MS="1800000"        # min 30m between scores polls
ODDS_SETTLE_BUFFER_S="7200"              # only poll scores 2h+ after kickoff
ODDS_FETCH_BEFORE_S="3600"               # only fetch odds for matches within 1h of kickoff (lineups)

# Protocol fee on prize payouts, basis points (250 = 2.5%)
PROTOCOL_FEE_BPS="250"
# Odds boost factor in bps (5000 = 0.5×) — bigger odds → bigger boost, capped by reserve:
PROTOCOL_BOOST_BPS="5000"

# Yield Agent (autonomous Morpho rebalancing via WDK wallet)
AGENT_MIN_APY_GAIN_BPS="30"              # min APY improvement (bps) to migrate
AGENT_MIN_TVL_USD="10"                   # risk floor — do not migrate into thinner vaults
AGENT_AUTO_REBALANCE="false"             # true = agent executes migrations on its own

# ─── Contracts: deploy + verify (packages/contracts) ───────────
WALLET_PK=""                # (secret) deployer private key, 0x…
ETHERSCAN_API_KEY=""        # (secret) Arbiscan key for contract verification
# Oracle key (ORACLE_ROLE) — API creates + settles markets on-chain:
ORACLE_PK=""                # (secret) usually the deployer
# LayerZero cross-chain deposit config (optional — deploy has Arbitrum defaults):
LZ_ENDPOINT=""
USDT0_OFT=""

# ─── Web app (apps/app) — put these in apps/app/.env.local ─────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_ARBITRUM_RPC="https://arb1.arbitrum.io/rpc"

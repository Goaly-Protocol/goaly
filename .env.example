# ─── Chain / RPC ───────────────────────────────────────────────
# Arbitrum One mainnet RPC — used by the indexer and by Foundry fork/integration tests.
ARBITRUM_RPC_URL="https://arb1.arbitrum.io/rpc"

# ─── Ponder indexer ────────────────────────────────────────────
# Ponder reads RPC per chain id (42161 = Arbitrum One).
PONDER_RPC_URL_42161="https://arb1.arbitrum.io/rpc"

# ─── API (apps/api) ────────────────────────────────────────────
API_PORT="3001"
# SQLite file path (relative to repo root). Tests use an in-memory DB.
DATABASE_URL="./data/goalyield.db"

# ─── The Odds API (https://the-odds-api.com) ───────────────────
# ONE key:
THE_ODDS_API_KEY=""
# …or MANY keys (comma-separated) for rotation/fallback. Each free key = 500
# credits/month, so N keys ≈ N×500 headroom. Takes precedence over the single key.
THE_ODDS_API_KEYS=""
ODDS_SPORT_KEY="soccer_fifa_world_cup"
ODDS_REGION="eu"
ODDS_MARKETS="h2h"
# Credit budget guardrails (free tier = 500/month):
ODDS_MONTHLY_CREDITS="500"
ODDS_CREDIT_RESERVE="80"                 # held back for settlement (scores)
ODDS_REFRESH_INTERVAL_MS="21600000"      # min 6h between (expensive) odds refreshes
ODDS_SCORES_INTERVAL_MS="1800000"        # min 30m between scores polls
ODDS_SETTLE_BUFFER_S="7200"              # only poll scores 2h+ after kickoff

# Protocol fee on pot payouts, basis points (250 = 2.5%)
PROTOCOL_FEE_BPS="250"

# ─── Contract deploy + indexing ────────────────────────────────
# Deployer key used by the Foundry deploy script (packages/contracts).
WALLET_PK=""
# Filled after deploy — consumed by the Ponder indexer (apps/indexer):
GOALY_VAULT_ADDRESS=""
GOALY_VAULT_START_BLOCK="0"
